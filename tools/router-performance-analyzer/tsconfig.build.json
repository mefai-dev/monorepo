{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "lib": ["es2021"],
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "dist",
    "composite": true,
    "tsBuildInfoFile": "./tsconfig.tsBuildInfo",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["test/**/*.ts"],
  "include": ["src/**/*.ts"]
}
